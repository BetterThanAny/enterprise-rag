# Copy names only; provide real values through your shell or `op run --env-file=.env -- <cmd>`.
POSTGRES_DB=enterprise_rag
POSTGRES_USER=enterprise_rag
POSTGRES_PASSWORD=<set-a-local-password>
DATABASE_URL=postgresql+psycopg://enterprise_rag:<url-encoded-password>@postgres:5432/enterprise_rag
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=10

REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=<set-a-local-access-key>
MINIO_SECRET_KEY=<set-a-local-secret-key>
MINIO_BUCKET=enterprise-rag-documents
MINIO_SECURE=false

JWT_SECRET=<set-at-least-32-random-characters>
ENVIRONMENT=development
LOG_LEVEL=INFO

RETRIEVAL_RRF_RANK_CONSTANT=60
RETRIEVAL_CONFIG_VERSION=postgres-fts-pgvector-rrf-v1
# `deterministic` is the explicit no-cost development/test stub.
# Use `fastembed` for real local 384-dimensional semantic retrieval.
EMBEDDING_PROVIDER=deterministic
FASTEMBED_MODEL_NAME=BAAI/bge-small-en-v1.5
FASTEMBED_CACHE_DIR=~/.cache/enterprise-rag/fastembed
FASTEMBED_BATCH_SIZE=64
RERANKER_PROVIDER=deterministic
RERANKER_MODEL_NAME=ms-marco-TinyBERT-L-2-v2
RERANKER_CACHE_DIR=~/.cache/enterprise-rag/flashrank

GENERATION_PROVIDER=deterministic
GENERATION_TIMEOUT_SECONDS=30
GENERATION_PROMPT_VERSION=grounded-citations-v1
GENERATION_CONFIG_VERSION=openai-compatible-chat-v1
PROVIDER_MAX_ATTEMPTS=3
PROVIDER_RETRY_BASE_SECONDS=0.25
PROVIDER_RETRY_MAX_SECONDS=5

# Cost rates are deployment-owned/versioned inputs; zero means cost is unavailable/free.
OPENAI_INPUT_COST_PER_MILLION_USD=0
OPENAI_OUTPUT_COST_PER_MILLION_USD=0
DEEPSEEK_INPUT_COST_PER_MILLION_USD=0
DEEPSEEK_OUTPUT_COST_PER_MILLION_USD=0

# Optional OTLP/HTTP traces endpoint, for example http://otel-collector:4318/v1/traces.
OTEL_EXPORTER_OTLP_ENDPOINT=

# Remote keys should be injected with `op run`; never commit real values.
OPENAI_API_KEY=<inject-with-op-run>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini
DEEPSEEK_API_KEY=<inject-with-op-run>
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Local OpenAI-compatible Ollama endpoint; installing/running Ollama is optional.
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_PORT=11434
